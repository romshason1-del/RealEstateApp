# StreetIQ Environment Variables
# Copy this file to .env.local for local development.
# For Vercel: Add these in Project Settings → Environment Variables.

# Required: Google Maps API key for map, Places, and Geocoding.
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Places API, Geocoding API
# NEXT_PUBLIC_* is used client-side; GOOGLE_MAPS_API_KEY is optional server-side fallback for geocode API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: Custom Map ID for dark mode. Create in Google Cloud Console → Map Management:
# Create a Map ID, associate a Dark style, then use that ID here.
# If unset, uses DEMO_MAP_ID (light theme).
# NEXT_PUBLIC_GOOGLE_MAP_ID=

# Supabase (auth + database)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server-side only, for admin operations like deleteUser)
SUPABASE_SERVICE_ROLE_KEY=
# Database URL for migrations (Supabase Dashboard > Project Settings > Database > Connection string URI)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Property Value Providers
# Israel: "official" (Tax Authority API when configured) | "mock" (development)
# Unset = "Official government transaction source is not configured yet."
PROPERTY_PROVIDER_ISRAEL=

# Israel Tax Authority API (future integration)
# ISRAEL_TAX_API_BASE_URL=
# ISRAEL_TAX_API_KEY=
# ISRAEL_TAX_API_CLIENT_ID=
# ISRAEL_TAX_API_CLIENT_SECRET=
# ISRAEL_TAX_API_ENDPOINT_TRANSACTIONS=
# ISRAEL_TAX_API_TIMEOUT_MS=15000
# ISRAEL_TAX_API_RETRIES=2

# United States: "rentcast" | "government" | "us-orchestrator" (government-only when RentCast paused)
# government / us-orchestrator = Census + FHFA only (no RentCast, Zillow, Redfin)
PROPERTY_PROVIDER_US=government

# RentCast API (United States)
RENTCAST_API_KEY=
RENTCAST_API_BASE_URL=https://api.rentcast.io/v1
# RENTCAST_API_TIMEOUT_MS=20000
# RENTCAST_RETRIES=2

# US Census Bureau (neighborhood stats). Optional for tract-level; required for ZCTA (ZIP) fallback.
CENSUS_API_KEY=

# FRED API (FHFA House Price Index for market trend). Get key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# UK EPC (Energy Performance Certificate). Register: https://epc.opendatacommunities.org/
# Used for floor area → improves "Exact value" when no transaction exists
EPC_API_EMAIL=
EPC_API_KEY=

# BigQuery (France real estate - single source of truth)
# Required for France property value data. Use gcloud auth application-default login or service account.
GOOGLE_CLOUD_PROJECT_ID=
# Optional: path to service account JSON key. If unset, uses Application Default Credentials.
GOOGLE_APPLICATION_CREDENTIALS=
# Optional: defaults to real_estate_data / france_transactions
# Note: Python upload script creates france_2024 by default; set BIGQUERY_TABLE=france_2024 if needed
BIGQUERY_DATASET=real_estate_data
BIGQUERY_TABLE=france_transactions
# France rich source: when "true", query raw DVF (france_transactions) for same-address rows before property_latest_facts
# Requires BIGQUERY_PROJECT_ID + credentials. Improves coverage for addresses missing from property_latest_facts.
FRANCE_RICH_SOURCE_ENABLED=
# Required for CloudRegion: use EU (dataset default), US, or region like europe-west1. Do NOT use FR or country codes.
BIGQUERY_LOCATION=EU
